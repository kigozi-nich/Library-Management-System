{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build TypeScript and show dist",
      "type": "shell",
      "command": "npx tsc; dir dist",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Run compiled app",
      "type": "shell",
      "command": "node dist/index.js",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
